#if canImport(AppKit)
import AppKit
#elseif canImport(UIKit)
import UIKit
#endif
import SwiftUI

#if canImport(AppKit)
public typealias PlatformColor = NSColor
public typealias PlatformImage = NSImage
public typealias PlatformFont = NSFont
#elseif canImport(UIKit)
public typealias PlatformColor = UIColor
public typealias PlatformImage = UIImage
public typealias PlatformFont = UIFont
#endif

public typealias R = Resource

public enum Resource { }

public extension Resource {
    struct ColorResource: Sendable {
        // MARK: - Property
        public let platformColor: PlatformColor
        public var color: SwiftUI.Color {
            #if canImport(AppKit)
            SwiftUI.Color(nsColor: platformColor)
            #elseif canImport(UIKit)
            SwiftUI.Color(uiColor: platformColor)
            #endif
        }
        
        // MARK: - Initializer
        public init(named name: Swift.String, in bundle: Bundle) {
            #if canImport(AppKit)
            self.platformColor = PlatformColor(named: name, bundle: bundle)!
            #elseif canImport(UIKit)
            self.platformColor = PlatformColor(named: name, in: bundle, compatibleWith: nil)!
            #endif
        }
        
        public init(_ color: PlatformColor) {
            self.platformColor = color
        }
        
        // MARK: - Public
        public func callAsFunction() -> PlatformColor {
            platformColor
        }
        
        public func callAsFunction() -> SwiftUI.Color {
            color
        }
        
        public func alpha(_ alpha: CGFloat) -> ColorResource {
            ColorResource(platformColor.withAlphaComponent(alpha))
        }
        
        // MARK: - Private
    }

    struct ImageResource: Sendable {
        // MARK: - Property
        public let platformImage: PlatformImage
        public var image: SwiftUI.Image {
            #if canImport(AppKit)
            SwiftUI.Image(nsImage: platformImage)
            #elseif canImport(UIKit)
            SwiftUI.Image(uiImage: platformImage)
            #endif
        }
        
        // MARK: - Initializer
        public init(named name: Swift.String, in bundle: Bundle) {
            #if canImport(AppKit)
            self.platformImage = bundle.image(forResource: name)!
            #elseif canImport(UIKit)
            self.platformImage = PlatformImage(named: name, in: bundle, compatibleWith: nil)!
            #endif
        }
        
        public init(_ image: PlatformImage) {
            self.platformImage = image
        }
        
        // MARK: - Public
        public func callAsFunction() -> PlatformImage {
            platformImage
        }
        
        public func callAsFunction() -> SwiftUI.Image {
            image
        }
        
        public func glyph() -> ImageResource {
            #if canImport(AppKit)
            let copy = platformImage.copy() as! PlatformImage
            copy.isTemplate = true
            
            return ImageResource(copy)
            #elseif canImport(UIKit)
            ImageResource(platformImage.withRenderingMode(.alwaysTemplate))
            #endif
        }

        // MARK: - Private
    }

    struct StringResource: Sendable {
        // MARK: - Property
        public let string: Swift.String

        // MARK: - Initializer
        public init(_ key: Swift.String, tableName: Swift.String? = nil, in bundle: Bundle, default value: Swift.String) {
            self.string = NSLocalizedString(key, tableName: tableName, bundle: bundle, value: value, comment: "")
        }

        public init(_ string: Swift.String) {
            self.string = string
        }

        // MARK: - Public
        public func callAsFunction() -> Swift.String {
            string
        }

        // MARK: - Private
    }
    
    struct FontResource: @unchecked Sendable {
        // MARK: - Property
        public let platformFont: PlatformFont
        public var font: SwiftUI.Font {
            #if canImport(AppKit)
            SwiftUI.Font(platformFont)
            #elseif canImport(UIKit)
            SwiftUI.Font(platformFont)
            #endif
        }
        
        // MARK: - Initializer
        public init(_ font: PlatformFont) {
            self.platformFont = font
        }

        // MARK: - Public
        public func callAsFunction() -> PlatformFont {
            platformFont
        }
        
        public func callAsFunction() -> SwiftUI.Font {
            font
        }
        
        // MARK: - Private
    }
}
